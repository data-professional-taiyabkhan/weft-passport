# ============================================================
# WEFT PASSPORT — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env or .env.local to Git
# ============================================================

# --- Supabase (get from: supabase.com > Project Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- App ---
NEXT_PUBLIC_APP_URL=https://your-vercel-domain.vercel.app
NEXT_PUBLIC_APP_NAME=Weft Passport

# ============================================================
# SETUP INSTRUCTIONS FOR MAHJABEEN
# ============================================================
# 1. Go to supabase.com and open your project
# 2. Settings → API → copy "Project URL" → paste as NEXT_PUBLIC_SUPABASE_URL
# 3. Settings → API → copy "anon public" key → paste as NEXT_PUBLIC_SUPABASE_ANON_KEY
# 4. Settings → API → copy "service_role" key → paste as SUPABASE_SERVICE_ROLE_KEY
# 5. Go to SQL Editor in Supabase → paste contents of supabase/schema.sql → Run
# 6. In Vercel: Settings → Environment Variables → add all 5 variables above
# 7. Redeploy from Vercel dashboard
# ============================================================
